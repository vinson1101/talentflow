# TalentFlow 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===========================
# 飞书配置（可选）
# ===========================
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx

# ===========================
# AI模型配置（可选）
# ===========================
# 默认使用系统配置的模型
# AI_MODEL=zhipu/glm-4.7

# ===========================
# 日志配置（可选）
# ===========================
LOG_LEVEL=INFO
LOG_FILE=logs/talentflow.log

# ===========================
# 文件处理配置（可选）
# ===========================
# 最大文件大小（MB）
MAX_FILE_SIZE=100
# 支持的文件类型
SUPPORTED_FILE_TYPES=pdf,docx,doc,png,jpg,jpeg
